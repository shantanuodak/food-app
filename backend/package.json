{
  "name": "food-app-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist/testing-dashboard && cp src/testing-dashboard/index.html dist/testing-dashboard/index.html",
    "start": "node dist/index.js",
    "migrate": "tsx src/scripts/migrate.ts",
    "benchmark:replay": "tsx src/scripts/replayBenchmark.ts",
    "benchmark:e2e": "tsx src/scripts/e2ePerformance.ts",
    "eval": "tsx src/scripts/runEval.ts",
    "eval:diff": "tsx src/scripts/evalDiff.ts",
    "eval:golden": "tsx src/scripts/goldenSetEval.ts",
    "preflight:release": "tsx src/scripts/releasePreflight.ts",
    "release:backend": "npm run build && npm test && npm run test:integration && npm run preflight:release",
    "test": "vitest run",
    "test:integration": "RUN_INTEGRATION_TESTS=true vitest run tests/integration.api.test.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
